-- Hooks do Silent Aim com ProteÃ§Ã£o pcall
pcall(function()
    local mt = getrawmetatable(game)
    local oldIndex = mt.__index
    local oldNamecall = mt.__namecall
    setreadonly(mt, false)

    local InHook = false

    mt.__index = newcclosure(function(self, key)
        if Settings.SilentEnabled and not InHook and not checkcaller() then
            if tostring(self) == "Mouse" and (key == "Hit" or key == "Target") then
                InHook = true
                local _, targetPart = getClosestTarget(true)
                InHook = false
                if targetPart then
                    if key == "Hit" then return targetPart.CFrame
                    elseif key == "Target" then return targetPart end
                end
            end
        end
        return oldIndex(self, key)
    end)

    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if Settings.SilentEnabled and not InHook and not checkcaller() then
            if method == "Raycast" and self == workspace then
                InHook = true
                local _, targetPart = getClosestTarget(true)
                InHook = false
                if targetPart then
