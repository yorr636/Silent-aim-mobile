local function updateFovCircles()
    local centerX = camera.ViewportSize.X / 2
    local centerY = camera.ViewportSize.Y / 2
    if AimFovCircle then
        AimFovCircle.Visible = Settings.AimbotFovEnabled
        AimFovCircle.Radius = Settings.AimbotFovRadius
        AimFovCircle.Position = Vector2.new(centerX, centerY)
    end
    if SilentFovCircle then
        SilentFovCircle.Visible = Settings.SilentFovEnabled
        SilentFovCircle.Radius = Settings.SilentFovRadius
        SilentFovCircle.Position = Vector2.new(centerX, centerY)
    end
end

local GlobalRaycastParams = RaycastParams.new()
GlobalRaycastParams.FilterType = Enum.RaycastFilterType.Exclude
GlobalRaycastParams.IgnoreWater = true

local function isVisible(targetPart)
    local success, visible = pcall(function()
        if not targetPart or not targetPart.Parent then return false end
        local character = LocalPlayer.Character
        if not character then return false end
        local origin = camera.CFrame.Position
        local direction = targetPart.Position - origin
        GlobalRaycastParams.FilterDescendantsInstances = {character, targetPart.Parent}
        return workspace:Raycast(origin, direction, GlobalRaycastParams) == nil
    end)
    return success and visible
end

local function getClosestTarget(isSilent)
    local fovRadius = isSilent and Settings.SilentFovRadius or Settings.AimbotFovRadius
    local teamCheck = isSilent and Settings.SilentTeamCheck or Settings.AimbotTeamCheck
    local wallCheck = isSilent and Settings.SilentWallCheck or Settings.AimbotWallCheck
    local targetPartName = isSilent and Settings.SilentTargetPart or Settings.AimbotTargetPart
    local botSupport = isSilent and Settings.SilentBotSupport or Settings.AimbotBotSupport

    local closestTarget, closestPart = nil, nil
    local shortestDistance = math.huge
    local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if teamCheck and player.Team == LocalPlayer.Team then continue end
            local char = player.Character
            if char then
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                local targetPart = char:FindFirstChild(targetPartName)
                if humanoid and humanoid.Health > 0 and targetPart then
                    local screenPos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
                    if onScreen then
                        local distance = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                        if distance <= fovRadius then
                            if wallCheck and not isVisible(targetPart) then continue end
                            if distance < shortestDistance then
                                shortestDistance = distance; closestTarget = player; closestPart = targetPart
                            end
                        end
                    end
                end
            end
        end
    end

    if botSupport then
        for _, bot in ipairs(BotList) do
            if bot and bot.Parent then
                local humanoid = bot:FindFirstChildOfClass("Humanoid")
                local targetPart = bot:FindFirstChild(targetPartName) or bot:FindFirstChild("Head") or bot:FindFirstChild("HumanoidRootPart")
                if humanoid and humanoid.Health > 0 and targetPart then
                    local screenPos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
                    if onScreen then
                        local distance = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                        if distance <= fovRadius then
                            if wallCheck and not isVisible(targetPart) then continue end
                            if distance < shortestDistance then
                                shortestDistance = distance; closestTarget = bot; closestPart = targetPart
                            end
                        end
                    end
                end
            end
        end
    end
    return closestTarget, closestPart
end

RunService.RenderStepped:Connect(function()
    updateFovCircles()
    if Settings.AimbotEnabled then
        local _, targetPart = getClosestTarget(false)
        if targetPart then
            if Settings.AimbotInstant then
                camera.CFrame = CFrame.new(camera.CFrame.Position, targetPart.Position)
            else
                camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, targetPart.Position), Settings.AimbotSmoothness)
            end
        end
    end
end)

local function applyChamsToCharacter(char, isAlly)
    if not char then return end
    if char:FindFirstChild("NexusHighlight") then char.NexusHighlight:Destroy() end
    local highlight = Instance.new("Highlight")
    highlight.Name = "NexusHighlight"
    highlight.Parent = char
    highlight.FillColor = isAlly and Color3.fromRGB(0, 255, 127) or Color3.fromRGB(255, 50, 50)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.45
    highlight.OutlineTransparency = 0.1
    ActiveHighlights[char] = highlight
end

task.spawn(function()
    while task.wait(1.5) do
        for char, highlight in pairs(ActiveHighlights) do
            if not char or not char.Parent or not char:FindFirstChildOfClass("Humanoid") or char:FindFirstChildOfClass("Humanoid").Health <= 0 then
                pcall(function() highlight:Destroy() end)
                ActiveHighlights[char] = nil
            end
        end
        local tempBots = {}
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("Model") and desc:FindFirstChildOfClass("Humanoid") then
                if not Players:GetPlayerFromCharacter(desc) and desc:FindFirstChildOfClass("Humanoid").Health > 0 and desc ~= LocalPlayer.Character then
                    table.insert(tempBots, desc)
                end
            end
        end
        BotList = tempBots
        if Settings.ChamsEnabled then
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local isAlly = (player.Team == LocalPlayer.Team)
                    if Settings.ChamsTeamCheck and isAlly then
                        if player.Character:FindFirstChild("NexusHighlight") then player.Character.NexusHighlight:Destroy() end
                    else
                        applyChamsToCharacter(player.Character, isAlly)
                    end
                end
            end
            for _, bot in ipairs(BotList) do applyChamsToCharacter(bot, false) end
        else
            for char, highlight in pairs(ActiveHighlights) do pcall(function() highlight:Destroy() end) end
            table.clear(ActiveHighlights)
        end
    end
end)

