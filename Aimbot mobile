local function updateFovCircles()
    local centerX = camera.ViewportSize.X / 2; local centerY = camera.ViewportSize.Y / 2
    if AimFovCircle then
        AimFovCircle.Visible = Settings.AimbotFovEnabled; AimFovCircle.Radius = Settings.AimbotFovRadius; AimFovCircle.Position = Vector2.new(centerX, centerY)
    end
    if SilentFovCircle then
        SilentFovCircle.Visible = Settings.SilentFovEnabled; SilentFovCircle.Radius = Settings.SilentFovRadius; SilentFovCircle.Position = Vector2.new(centerX, centerY)
    end
end

local GlobalRaycastParams = RaycastParams.new()
GlobalRaycastParams.FilterType = Enum.RaycastFilterType.Exclude; GlobalRaycastParams.IgnoreWater = true

local function isVisible(targetPart)
    local s, v = pcall(function()
        local char = LocalPlayer.Character
        if not char then return false end
        GlobalRaycastParams.FilterDescendantsInstances = {char, targetPart.Parent}
        return workspace:Raycast(camera.CFrame.Position, targetPart.Position - camera.CFrame.Position, GlobalRaycastParams) == nil
    end)
    return s and v
end

local function calculateTarget(isSilent)
    local fovRadius = isSilent and Settings.SilentFovRadius or Settings.AimbotFovRadius
    local teamCheck = isSilent and Settings.SilentTeamCheck or Settings.AimbotTeamCheck
    local wallCheck = isSilent and Settings.SilentWallCheck or Settings.AimbotWallCheck
    local targetPartName = isSilent and Settings.SilentTargetPart or Settings.AimbotTargetPart
    local botSupport = isSilent and Settings.SilentBotSupport or Settings.AimbotBotSupport

    local bestPart = nil
    local shortestDistance = math.huge
    local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)

    local function checkEntity(character)
        if not character then return end
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        local targetPart = character:FindFirstChild(targetPartName) or character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
        
        if humanoid and humanoid.Health > 0 and targetPart then
            local screenPos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
            if onScreen then
                local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                if dist <= fovRadius then
                    if wallCheck and not isVisible(targetPart) then return end
                    if dist < shortestDistance then shortestDistance = dist; bestPart = targetPart end
                end
            end
        end
    end

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if teamCheck and player.Team == LocalPlayer.Team then continue end
            checkEntity(player.Character)
        end
    end
    if botSupport then for _, bot in ipairs(BotList) do checkEntity(bot) end end

    return bestPart
end

-- RENDERIZAÇÃO PRINCIPAL (Alimenta o Cache para evitar lag nos Tiros)
RunService.RenderStepped:Connect(function()
    updateFovCircles()
    
    -- Atualiza os alvos 1x por frame, evitando cálculos repetidos pesados
    if Settings.SilentEnabled then CurrentSilentTarget = calculateTarget(true) else CurrentSilentTarget = nil end
    if Settings.AimbotEnabled then CurrentAimTarget = calculateTarget(false) else CurrentAimTarget = nil end

    if Settings.AimbotEnabled and CurrentAimTarget then
        if Settings.AimbotInstant then
            camera.CFrame = CFrame.new(camera.CFrame.Position, CurrentAimTarget.Position)
        else
            camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, CurrentAimTarget.Position), Settings.AimbotSmoothness)
        end
    end
end)

-- CHAMS (Bordas brancas removidas)
local function applyChams(char, isAlly)
    if not char then return end
    if char:FindFirstChild("NexusHighlight") then char.NexusHighlight:Destroy() end
    local highlight = Instance.new("Highlight")
    highlight.Name = "NexusHighlight"
    highlight.Parent = char
    highlight.FillColor = isAlly and Color3.fromRGB(0, 255, 127) or Color3.fromRGB(255, 50, 50)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 1 -- Borda 100% INVISÃVEL
    ActiveHighlights[char] = highlight
end

task.spawn(function()
    while task.wait(1) do
        for char, h in pairs(ActiveHighlights) do
            if not char or not char.Parent or not char:FindFirstChildOfClass("Humanoid") or char:FindFirstChildOfClass("Humanoid").Health <= 0 then
                pcall(function() h:Destroy() end); ActiveHighlights[char] = nil
            end
        end
        local tempBots = {}
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("Model") and desc:FindFirstChildOfClass("Humanoid") and not Players:GetPlayerFromCharacter(desc) and desc ~= LocalPlayer.Character then
                if desc:FindFirstChildOfClass("Humanoid").Health > 0 then table.insert(tempBots, desc) end
            end
        end
        BotList = tempBots
        
        if Settings.ChamsEnabled then
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local isAlly = (player.Team == LocalPlayer.Team)
                    if Settings.ChamsTeamCheck and isAlly then
                        if player.Character:FindFirstChild("NexusHighlight") then player.Character.NexusHighlight:Destroy() end
                    else applyChams(player.Character, isAlly) end
                end
            end
            for _, bot in ipairs(BotList) do applyChams(bot, false) end
        else
            for char, h in pairs(ActiveHighlights) do pcall(function() h:Destroy() end) end
            table.clear(ActiveHighlights)
        end
    end
end)

-- SILENT AIM HOOK (Agora 100% sem lag usando o Cache de Alvo)
pcall(function()
    local mt = getrawmetatable(game)
    local oldIndex = mt.__index
    local oldNamecall = mt.__namecall
    setreadonly(mt, false)

    mt.__index = newcclosure(function(self, key)
        if Settings.SilentEnabled and not checkcaller() and CurrentSilentTarget then
            if tostring(self) == "Mouse" then
                if key == "Hit" then return CurrentSilentTarget.CFrame
                elseif key == "Target" then return CurrentSilentTarget end
            end
        end
        return oldIndex(self, key)
    end)

    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if Settings.SilentEnabled and not checkcaller() and CurrentSilentTarget then
            if method == "Raycast" and self == workspace then
                local origin = args[1]
                local direction = args[2]
                args[2] = (CurrentSilentTarget.Position - origin).Unit * (direction.Magnitude > 0 and direction.Magnitude or 1000)
                return oldNamecall(self, unpack(args))
                
            elseif (method == "FindPartOnRay" or method == "FindPartOnRayWithIgnoreList") and self == workspace then
                args[1] = Ray.new(args[1].Origin, (CurrentSilentTarget.Position - args[1].Origin).Unit * args[1].Direction.Magnitude)
                return oldNamecall(self, unpack(args))
                
            elseif (method == "ScreenPointToRay" or method == "ViewportPointToRay") and self == camera then
                return Ray.new(camera.CFrame.Position, (CurrentSilentTarget.Position - camera.CFrame.Position).Unit)
                
            elseif (method == "FireServer" or method == "InvokeServer") then
                local remoteName = tostring(self):lower()
                if remoteName:find("shoot") or remoteName:find("fire") or remoteName:find("bullet") or remoteName:find("hit") then
                    for i, arg in ipairs(args) do
                        if typeof(arg) == "Vector3" then args[i] = CurrentSilentTarget.Position
                        elseif typeof(arg) == "CFrame" then args[i] = CurrentSilentTarget.CFrame
                        elseif typeof(arg) == "Instance" and (arg:IsA("Player") or arg:IsA("Model")) then args[i] = CurrentSilentTarget.Parent end
                    end
                    return oldNamecall(self, unpack(args))
                end
            end
        end
        return oldNamecall(self, ...)
    end)
    setreadonly(mt, true)
